# Connections
PORT=8080
HOST=0.0.0.0
CONNECTION__DB_HOST=chromadb
CONNECTION__DB_PORT=8000
CONNECTION__DB_TYPE=ChromaDB
CONNECTION__REDIS_HOST=redis
CONNECTION__REDIS_PORT=6379
#UI
UI_SETTINGS__CHAT_SERVICE_URL=http://localhost:8000/chat
# DB_RETRIEVAL
DB_RETRIEVAL__NN_COUNT=5

# SYSTEM
SYSTEM__ALLOWED_ORIGINS=*
APP_ENV=local
# SYSTEM__MODELS
SYSTEM__MODELS__CHUNKING_MODEL=text-embedding-3-small
SYSTEM__MODELS__EMBEDDING_MODEL=text-embedding-3-small
SYSTEM__MODELS__LLM_MODEL=gpt-4o-mini

# SYSTEM__LLM_SETTINGS
SYSTEM__LLM_SETTINGS__LLM_TEMPERATURE=0.7
SYSTEM__LLM_SETTINGS__LLM_MAX_TOKENS=2000
SYSTEM__LLM_SETTINGS__LLM_RAG_ENABLED=true

# SYSTEM__LLM_INTENT_PROVIDER
SYSTEM__LLM_INTENT_PROVIDER__HOST=http://localhost:11434
SYSTEM__LLM_INTENT_PROVIDER__PROVIDER=ollama
SYSTEM__LLM_INTENT_PROVIDER__MODEL=llama3

# SYSTEM__CHUNK_SETTINGS
SYSTEM__CHUNK_SETTINGS__CHUNK_SIZE=500
SYSTEM__CHUNK_SETTINGS__CHUNK_OVERLAP=50

# PERSONA_SETTINGS
PERSONA_SETTINGS__PERSONA_TEMP=0.1
PERSONA_SETTINGS__CODE_EXPLANATION=0.5
PERSONA_SETTINGS__TECH_EXPLANATION=0.5
PERSONA_SETTINGS__PERSONA_COLLECTION_NAME=jag_bio
#GCP
FILE_LOCATIONS__GCP_BUCKET_NAME=Profile
### temp setting will have to move to cloud storage
FILE_LOCATIONS__DOCUMENT_TO_PROCESS_DIR = data/input_rag
FILE_LOCATIONS__DOCUMENT_PROCESSED_DIR = data/output_rag

